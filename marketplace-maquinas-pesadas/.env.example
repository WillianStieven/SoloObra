# Exemplo de variáveis de ambiente
# Copie este arquivo para .env.local e preencha com seus valores

# API Keys (quando implementar backend)
# NEXT_PUBLIC_API_URL=http://localhost:3001
# DATABASE_URL=postgresql://user:password@localhost:5432/marketplace

# Payment Gateway (quando implementar)
# STRIPE_PUBLIC_KEY=pk_test_...
# MERCADO_PAGO_PUBLIC_KEY=TEST-...

# Maps API (quando implementar geolocalização)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Authentication (quando implementar)
# JWT_SECRET=your_jwt_secret_here
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_nextauth_secret_here


